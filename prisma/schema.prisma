// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  USER
  ADMIN
  ENCODER
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  firstName  String
  lastName   String
  middleName String?
  password   String
  userType   UserType @default(USER)
  createdAt  DateTime @default(now())
}

model Departments {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  link        String
  subTitle    String?
  description String?
  icon        String?
  color       String?

  reports DepartmentReports[]
}

model DepartmentReports {
  id           Int     @id @default(autoincrement())
  departmentId Int
  title        String
  url          String?
  description  String?

  createdAt  DateTime        @default(now())
  department Departments     @relation(fields: [departmentId], references: [id])
  metrics    ReportMetrics[]
}

model ReportMetrics {
  id          Int     @id @default(autoincrement())
  reportId    Int
  name        String
  value       Int
  description String?

  createdAt DateTime          @default(now())
  report    DepartmentReports @relation(fields: [reportId], references: [id])
}
